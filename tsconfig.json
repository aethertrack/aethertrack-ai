{
    "compilerOptions": {
        "target": "ES2020",        
        "module": "CommonJS",
        "declaration": true,
        "outDir": "dist",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "allowSyntheticDefaultImports": true,        
        "moduleResolution": "Node",
        "allowJs": false,
        "noEmitOnError": false
    },
    "include": ["src", "tests"],
    "exclude": ["node_modules", "dist"]
}