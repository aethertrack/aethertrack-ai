{
    "compilerOptions": {
        "target": "ES2020",        
        "module": "node16",
        "declaration": true,
        "outDir": "dist",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "allowSyntheticDefaultImports": true,        
        "moduleResolution": "node16",
        "allowJs": false,
        "noEmitOnError": false        
    },
    "include": ["src"],
    "exclude": ["node_modules", "dist"]
}