{
    "compilerOptions": {
        "target": "ES2020",
        "module": "Node16",
        "declaration": true,
        "outDir": "dist",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "moduleResolution": "node16",
        "resolveJsonModule": true
    },
    "include": ["src", "config/**/*.json",],
    "exclude": ["node_modules", "dist"]
}