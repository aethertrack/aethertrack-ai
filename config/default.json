{
    "appConfig": {},
    "providers": {
        "openai": {
            "connection1": {                
                "type": "openai",
                "apiKeyEnvVar": "OPENAI_API_KEY_1",
                "defaultModel": "gpt-5",
                "models": {
                    "gpt-5": {
                        "roles": ["chat", "stream"],
                        "embedOptions": {
                            "encodingFormat": "float",
                            "dimensions": 3072
                        },
                        "streamOptions": {}
                    },
                    "text-embedding-3-large": {
                        "roles": ["embed"],
                        "embedOptions": {
                            "encodingFormat": "float",
                            "dimensions": 3072
                        }
                    },
                    "gpt-3.5-turbo-instruct": {
                        "roles": ["completion"],
                        "completionOptions": {
                            "max_tokens": 512
                        }
                    },
                    "gpt-image-1": {
                        "roles": ["image"],
                        "imageOptions": {
                            "size": "1024x1024",
                            "n": 1
                        }
                    }
                }
            },
            "connection2": {
                "type": "openai",
                "apiKeyEnvVar": "OPENAI_API_KEY_2",
                "defaultModel": "gpt-5",
                "models": {
                    "gpt-5": {
                        "roles": ["chat", "completion", "stream"],
                        "embedOptions": {
                            "encodingFormat": "float",
                            "dimensions": 3072
                        },
                        "streamOptions": {}
                    },
                    "text-embedding-3-large": {
                        "roles": ["embed"],
                        "embedOptions": {
                            "encodingFormat": "float",
                            "dimensions": 3072
                        }
                    },
                    "gpt-3.5-turbo-instruct": {
                        "roles": ["completion"],
                        "completionOptions": {
                            "max_tokens": 512
                        }
                    },
                    "gpt-image-1": {
                        "roles": ["image"],
                        "imageOptions": {
                            "size": "1024x1024",
                            "n": 1
                        }
                    }
                }
            }            
        },
        "anthropic": {
            "connection1": { 
                "type": "anthropic",
                "apiKeyEnvVar": "ANTHROPIC_API_KEY_1",                
                "defaultModel": "claude-sonnet-4-5-20250929",
                "models": {
                    "claude-sonnet-4-5-20250929": {
                    }
                }
            }
        },
        "huggingface": {
            "connection1": {
                "type": "huggingface",
                "apiKeyEnvVar": "HUGGINGFACE_API_KEY_1",            
                "defaultModel": "tiiuae/falcon-7b-instruct",
                "models": {
                    "tiiuae/falcon-7b-instruct": {
                    }
                }
            }
        }
    }
}