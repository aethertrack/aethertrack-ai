{
    "defaultProvider": "openai",
    "providers": {
        "openai": {
            "name": "openai",
            "providerOptions": {
                "models": {
                    "gpt-5": {
                        "modelName": "gpt-5",
                        "genOptions": {
                            "max_output_tokens": 1024
                        }
                    },
                    "gpt-4": {
                        "modelName": "gpt-4",
                        "genOptions": {
                            "temperature": 0.5,
                            "max_output_tokens": 1024
                        }
                    },
                    "text-embedding-3-large": {
                        "modelName": "text-embedding-3-large",
                        "embedOptions": {
                            "encodingFormat": "float",
                            "dimensions": 3072
                        }
                    }
                }
            }
        }
    }
}