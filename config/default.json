{
    "defaultProvider": "openai",
    "providers": {
        "openai": {
            "name": "openai",
            "providerOptions": {
                "defaultModel": "gpt-5",          
                "models": {
                    "gpt-5": {
                        "genOptions": {
                            "max_output_tokens": 1024
                        }
                    },
                    "gpt-4": {
                        "genOptions": {
                            "temperature": 0.5,
                            "max_output_tokens": 1024
                        }
                    }
                }
            }
        }
    }
}