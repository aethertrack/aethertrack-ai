{
    "type": "module",
    "name": "aethertrack-ai",
    "version": "0.1.0",
    "description": "",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "private": true,
    "license": "MIT",
    "scripts": {
        "clean": "rimraf dist",
        "build": "npm run clean && tsc",
        "start": "node dist/index.js",
        "dev": "nodemon --watch src --ext ts --exec \"npm run build && npm run start\"",
        "test": "vitest run --coverage",
        "test:watch": "vitest"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/aethertrack/aethertrack-ai.git"
    },
    "bugs": {
        "url": "https://github.com/aethertrack/aethertrack-ai/issues"
    },
    "homepage": "https://github.com/aethertrack/aethertrack-ai#readme",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        }
    },
    "dependencies": {
        "@anthropic-ai/sdk": "^0.68.0",
        "@huggingface/inference": "^4.13.2",
        "axios": "^1.13.1",
        "commander": "^14.0.2",
        "config": "^4.1.1",
        "dotenv": "^17.2.3",
        "openai": "^6.9.0"
    },
    "devDependencies": {
        "@types/config": "^3.3.5",
        "@vitest/coverage-istanbul": "^4.0.8",
        "nodemon": "^3.1.10",
        "rimraf": "^6.1.0",
        "ts-node": "^10.9.2",
        "ts-node-dev": "^2.0.0",
        "typescript": "^5.9.3",
        "vitest": "^4.0.8"
    }
}
